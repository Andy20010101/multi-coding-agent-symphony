{
  "name": "multi-coding-agent-symphony",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "description": "A BDD and TDD built orchestrator for multiple coding CLIs.",
  "scripts": {
    "test": "node --test",
    "check": "node --check src/*.js src/adapters/*.js src/ensemble/*.js src/integrations/*.js src/trackers/*.js scripts/*.js plugins/eval-replay/*.js tests/*.test.js",
    "mcas": "node scripts/mcas.js",
    "smoke:codex:help": "codex exec --help",
    "smoke:codex:real": "node scripts/smoke-codex-real.js",
    "smoke:codex:writer": "node scripts/smoke-codex-writer.js",
    "smoke:harness:codex:real": "node scripts/smoke-harness-codex-real.js",
    "smoke:claude:help": "claude --help",
    "smoke:claude:real": "node scripts/smoke-claude-real.js",
    "smoke:kiro:help": "kiro-cli --help",
    "smoke:kiro:real": "node scripts/smoke-kiro-real.js",
    "eval:replay": "node scripts/eval-replay.js",
    "test:mutation": "stryker run",
    "test:mutation:gate": "stryker run"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/tap-runner": "^9.6.1",
    "fast-check": "^4.8.0"
  }
}
