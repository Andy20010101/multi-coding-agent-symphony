{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvidencePackage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "command",
    "taskId",
    "workspaceId",
    "diffSummary",
    "changedFiles",
    "checks",
    "knownRisks",
    "agentSummary",
    "version"
  ],
  "properties": {
    "command": {
      "type": "string",
      "enum": ["plan", "implement", "review", "fix-ci", "qa"]
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "diffSummary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "anyOf": [
          { "required": ["output"] },
          { "required": ["artifactId"] }
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed"]
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "exitCode": {
            "type": "integer"
          },
          "output": {
            "type": "string",
            "minLength": 1
          },
          "artifactId": {
            "type": "string",
            "minLength": 1
          },
          "startedAt": {
            "type": "string",
            "format": "date-time"
          },
          "finishedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "knownRisks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "agentSummary": {
      "type": "string",
      "minLength": 1
    },
    "noOpRationale": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "noFindingRationale": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    }
  }
}
