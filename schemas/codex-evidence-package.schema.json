{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodexEvidencePackage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "command",
    "taskId",
    "workspaceId",
    "diffSummary",
    "changedFiles",
    "checks",
    "knownRisks",
    "agentSummary",
    "noOpRationale",
    "findings",
    "noFindingRationale",
    "resourceProfile",
    "version"
  ],
  "properties": {
    "command": {
      "type": "string",
      "enum": ["plan", "implement", "review", "fix-ci", "qa"]
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "diffSummary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "command",
          "exitCode",
          "output",
          "artifactId",
          "startedAt",
          "finishedAt"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed"]
          },
          "command": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "exitCode": {
            "type": ["integer", "null"]
          },
          "output": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "artifactId": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "startedAt": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "finishedAt": {
            "type": ["string", "null"],
            "format": "date-time"
          }
        }
      }
    },
    "knownRisks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "agentSummary": {
      "type": "string",
      "minLength": 1
    },
    "noOpRationale": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "findings": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "noFindingRationale": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "resourceProfile": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["cpu", "memoryMb", "timeoutSeconds", "concurrency", "network", "version"],
      "properties": {
        "cpu": {
          "type": "string",
          "minLength": 1
        },
        "memoryMb": {
          "type": "integer",
          "minimum": 1
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "concurrency": {
          "type": "integer",
          "minimum": 1
        },
        "network": {
          "type": "string",
          "enum": ["enabled", "disabled", "restricted"]
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "version": {
      "type": "string",
      "minLength": 1
    }
  }
}
